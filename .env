# ── API Backend ──
# En desarrollo apunta al servidor Laravel local
VITE_API_URL=http://localhost:8000/api/v1

# En producción descomenta y ajusta esta línea:
# VITE_API_URL=https://tu-dominio.com/api/v1

# ── Google OAuth ──
# Obtén tu Client ID en: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID_AQUI

# ── App Info ──
VITE_APP_NAME="Tiza & Datos"
VITE_APP_VERSION=1.0.0
